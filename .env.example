# Backend/API (servidor Node/Express para checkout y contacto)
VITE_API_URL=http://localhost:3000

# Supabase Cloud. Dashboard → Project Settings → API → URL y anon public key.
# Solo usar la anon key en el frontend para usuarios finales.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Panel admin (escritura con RLS bypass). Service role del mismo proyecto.
# ⚠️ Vite inyecta VITE_* en el bundle: NO uses esta key en un despliegue público sin protección
# (mejor: backend propio o Edge Function que use la key solo en servidor).
VITE_SUPABASE_SERVICE_KEY=

# Stripe (frontend)
# ⚠️ ANTES DE PRODUCCIÓN: reemplazá por la publishable key LIVE (prefijo pk_live_...).
# En desarrollo suele ser pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=

