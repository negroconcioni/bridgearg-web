generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Obra {
  id         Int       @id @default(autoincrement())
  titulo     String
  precio     Int       // precio en centavos (legacy). Preferir price_usd.
  imagenUrl  String    @map("imagen_url")
  status     String    @default("available") // "available" | "reserved" | "sold"
  artistSlug String    @map("artist_slug")
  artistName String?   @map("artist_name")   // nullable si se usa artist_id (Supabase)
  year       String?
  medium     String?
  dimensions String?   // descripción libre (ej. "50 x 70 cm")
  priceUsd   Decimal?  @map("price_usd")    @db.Decimal(12, 2)  // USD, export
  weightKg   Decimal?  @map("weight_kg")    @db.Decimal(10, 3)
  widthCm    Decimal?  @map("width_cm")     @db.Decimal(8, 2)
  heightCm   Decimal?  @map("height_cm")    @db.Decimal(8, 2)
  depthCm    Decimal?  @map("depth_cm")     @db.Decimal(8, 2)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("obras")
}
