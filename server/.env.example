# Stripe (https://dashboard.stripe.com/apikeys). Webhook: apunta a POST https://tu-dominio/api/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_... # ⚠️ ANTES DE PRODUCCIÓN: reemplazar por sk_live_... o no habrá cobros reales
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=tu-email@tudominio.com

# Frontend (origen permitido para CORS)
CLIENT_URL=http://localhost:5173

# Base de datos (Supabase Postgres o local). Reemplazá con tu connection string.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabase (para webhook: marcar obra como 'sold' tras pago). Dashboard → Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
